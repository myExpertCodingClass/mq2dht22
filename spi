#include <SPI.h>
#include <DHT.h>

#define DHTPIN 2
#define DHTTYPE DHT11

#define MQ2_PIN A0
#define FLAME_PIN A1

#define SS_PIN 10

DHT dht(DHTPIN, DHTTYPE);

struct DataSensor {
  byte suhu;
  byte hum;
  int gas;
  int flame;
};

void setup() {

  pinMode(SS_PIN, OUTPUT);
  digitalWrite(SS_PIN, HIGH);

  SPI.begin();

  dht.begin();
}

void kirimByte(byte data) {
  SPI.transfer(data);
}

void loop() {

  DataSensor data;

  data.suhu = (byte)dht.readTemperature();
  data.hum = (byte)dht.readHumidity();
  data.gas = analogRead(MQ2_PIN);
  data.flame = analogRead(FLAME_PIN);

  digitalWrite(SS_PIN, LOW);

  kirimByte(data.suhu);
  kirimByte(data.hum);

  kirimByte(highByte(data.gas));
  kirimByte(lowByte(data.gas));

  kirimByte(highByte(data.flame));
  kirimByte(lowByte(data.flame));

  digitalWrite(SS_PIN, HIGH);

  delay(1000);
}

