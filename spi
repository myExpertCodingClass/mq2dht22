#include <SPI.h>

#define LED_MERAH 8
#define LED_BIRU 6
#define BUZZER_PIN 9

volatile byte indexData = 0;
volatile byte buffer[6];

byte suhu = 0;
byte hum = 0;
int gas = 0;
int flame = 0;

const int gasThreshold = 400;
const int flameThreshold = 500;
const int tempThreshold = 35;

ISR(SPI_STC_vect)
{
  byte c = SPDR;

  if (indexData < 6) {
    buffer[indexData++] = c;
  }

  if (indexData >= 6) {

    suhu = buffer[0];
    hum = buffer[1];

    gas = word(buffer[2], buffer[3]);
    flame = word(buffer[4], buffer[5]);

    indexData = 0;
  }
}

void setup() {

  pinMode(MISO, OUTPUT);

  pinMode(LED_MERAH, OUTPUT);
  pinMode(LED_BIRU, OUTPUT);
  pinMode(BUZZER_PIN, OUTPUT);

  SPCR |= _BV(SPE);
  SPI.attachInterrupt();

  Serial.begin(9600);
}

void loop() {

  bool bahaya = false;

  if (suhu > tempThreshold)
    bahaya = true;

  if (gas > gasThreshold)
    bahaya = true;

  if (flame < flameThreshold)
    bahaya = true;

  if (bahaya) {

    digitalWrite(LED_MERAH, HIGH);
    digitalWrite(LED_BIRU, LOW);

    tone(BUZZER_PIN, 2000);
  }
  else {

    digitalWrite(LED_MERAH, LOW);
    digitalWrite(LED_BIRU, HIGH);

    noTone(BUZZER_PIN);
  }

  Serial.print("Suhu: ");
  Serial.print(suhu);

  Serial.print(" | Hum: ");
  Serial.print(hum);

  Serial.print(" | Gas: ");
  Serial.print(gas);

  Serial.print(" | Flame: ");
  Serial.println(flame);

  delay(500);
}

